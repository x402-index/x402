{
  "name": "go-http",
  "type": "client",
  "language": "go",
  "protocolFamilies": [
    "evm",
    "svm"
  ],
  "x402Versions": [
    1,
    2
  ],
  "schemes": ["exact", "upto"],
  "evm": {
    "transferMethods": [
      "eip3009",
      "permit2",
      "upto"
    ]
  },
  "extensions": [
    "eip2612GasSponsoring",
    "erc20ApprovalGasSponsoring"
  ],
  "environment": {
    "required": [
      "EVM_PRIVATE_KEY",
      "SVM_PRIVATE_KEY",
      "RESOURCE_SERVER_URL",
      "ENDPOINT_PATH"
    ],
    "optional": [
      "EVM_RPC_URL"
    ]
  }
}